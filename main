local placeId = game.PlaceId
 
local scripts = {
    [110334393584385] = "https://raw.githubusercontent.com/Fafarove/roller/refs/heads/main/loader.lua",
    [136066387156306] = "https://raw.githubusercontent.com/Fafarove/dupeflash/refs/heads/main/loader.lua",
    [120217704230083] = "https://raw.githubusercontent.com/Fafarove/dungeonhunter/refs/heads/main/loader.lua",
    [121902496311296] = "https://raw.githubusercontent.com/Fafarove/dungeonhunter/refs/heads/main/loader.lua",
    [123911129955120] = "https://raw.githubusercontent.com/Fafarove/dungeonhunter/refs/heads/main/loader.lua",
    [116991059923076] = "https://raw.githubusercontent.com/Fafarove/dungeonhunter/refs/heads/main/loader.lua",
    [113880247399913] = "https://raw.githubusercontent.com/Fafarove/dungeonhunter/refs/heads/main/loader.lua",
    [121731448247552] = "https://raw.githubusercontent.com/Fafarove/dungeonhunter/refs/heads/main/loader.lua",
}
 
local url = scripts[placeId]
if url then
    loadstring(game:HttpGet(url))()
else
    warn("❌ No script available for this game.")
    game.StarterGui:SetCore("SendNotification", {
        Title = "⚠️ Unsupported Game",
        Text = "There is no script for this game yet.",
        Duration = 6
    })
end
